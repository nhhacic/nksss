rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Clinical images: only the owning doctor can upload/read/delete
    match /clinical_images/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Avatar uploads: only the owning user can upload/read/delete
    match /avatars/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Default: deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
